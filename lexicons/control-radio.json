{
  "lexicon": 1,
  "id": "pet.nkp.radio.control",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Perform an explicit admin radio playback action.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["action", "intent"],
          "properties": {
            "action": {
              "type": "string",
              "knownValues": [
                "play",
                "pause",
                "stop",
                "skip",
                "previous",
                "shuffle",
                "setLoopMode",
                "setLoopPlaylist"
              ]
            },
            "intent": {
              "type": "string",
              "knownValues": ["explicit_admin_action"]
            },
            "loopMode": {
              "type": "string",
              "description": "Required for setLoopMode: how finished queue tracks are recycled.",
              "knownValues": ["off", "one", "queue"]
            },
            "loopPlaylistId": {
              "type": "string",
              "description": "For setLoopPlaylist: the playlist to reload when the queue drains. Omit to stop looping a playlist."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["snapshot"],
          "properties": {
            "snapshot": {
              "type": "ref",
              "ref": "pet.nkp.radio#radioSnapshot"
            }
          }
        }
      },
      "errors": [
        { "name": "AuthenticationRequired" },
        { "name": "AdminRequired" },
        { "name": "InvalidRequest" }
      ]
    }
  }
}
