{
  "lexicon": 1,
  "id": "pet.nkp.radio.albums.modify",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Modify albums derived from song metadata: ungroup a messy album tag, or merge two differently-spelled album groups together.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["action", "albumId"],
          "properties": {
            "action": {
              "type": "string",
              "knownValues": ["delete", "merge"]
            },
            "albumId": {
              "type": "string"
            },
            "targetAlbumId": {
              "type": "string"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["albums"],
          "properties": {
            "albums": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "pet.nkp.radio#radioAlbum"
              }
            }
          }
        }
      },
      "errors": [
        { "name": "AuthenticationRequired" },
        { "name": "AdminRequired" },
        { "name": "InvalidRequest" }
      ]
    }
  }
}
