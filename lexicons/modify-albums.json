{
  "lexicon": 1,
  "id": "pet.nkp.radio.albums.modify",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Modify admin-defined album loops.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "action",
            "albumId"
          ],
          "properties": {
            "action": {
              "type": "string",
              "knownValues": [
                "delete",
                "setEnabled",
                "merge",
                "setWeight"
              ]
            },
            "albumId": {
              "type": "string"
            },
            "targetAlbumId": {
              "type": "string"
            },
            "enabled": {
              "type": "boolean"
            },
            "weight": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4,
              "description": "Rotation weight for setWeight: 1 light, 2 normal, 4 heavy."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "albums"
          ],
          "properties": {
            "albums": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "pet.nkp.radio#radioAlbum"
              }
            }
          }
        }
      },
      "errors": [
        {
          "name": "AuthenticationRequired"
        },
        {
          "name": "AdminRequired"
        },
        {
          "name": "InvalidRequest"
        }
      ]
    }
  }
}