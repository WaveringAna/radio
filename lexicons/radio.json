{
  "lexicon": 1,
  "id": "pet.nkp.radio",
  "description": "Shared data shapes for nkp radio XRPC endpoints.",
  "defs": {
    "song": {
      "type": "object",
      "description": "Song metadata stored by the radio backend.",
      "required": [
        "id",
        "title",
        "artist",
        "album",
        "genre",
        "durationSeconds",
        "mimeType",
        "hasCover",
        "addedByDid",
        "createdAt",
        "loudnessLufs",
        "loudnessPeak"
      ],
      "nullable": ["album", "genre", "durationSeconds", "mimeType", "loudnessLufs", "loudnessPeak"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable song id.",
          "minLength": 1,
          "maxLength": 128
        },
        "title": {
          "type": "string",
          "description": "Song title.",
          "minLength": 1,
          "maxLength": 512
        },
        "artist": {
          "type": "string",
          "description": "Song artist.",
          "minLength": 1,
          "maxLength": 512
        },
        "album": {
          "type": "string",
          "description": "Optional album title."
        },
        "genre": {
          "type": "string",
          "description": "Optional genre."
        },
        "durationSeconds": {
          "type": "integer",
          "description": "Optional duration in seconds."
        },
        "mimeType": {
          "type": "string",
          "description": "Stored audio MIME type."
        },
        "hasCover": {
          "type": "boolean",
          "description": "Whether the song has cover art."
        },
        "addedByDid": {
          "type": "string",
          "description": "DID that uploaded the song."
        },
        "createdAt": {
          "type": "integer",
          "description": "Unix timestamp when the song was uploaded.",
          "minimum": 0
        },
        "loudnessLufs": {
          "type": "string",
          "description": "Integrated loudness in LUFS, serialized as a decimal string."
        },
        "loudnessPeak": {
          "type": "string",
          "description": "True peak in dBFS, serialized as a decimal string."
        }
      }
    },
    "queueItem": {
      "type": "object",
      "description": "Queue item joined with song metadata.",
      "required": ["id", "position", "queuedByDid", "songId", "song", "title", "artist", "album", "durationSeconds", "addedByDid"],
      "nullable": ["album", "durationSeconds"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable queue item id.",
          "minLength": 1,
          "maxLength": 128
        },
        "position": {
          "type": "integer",
          "description": "Queue position, lower values play first.",
          "minimum": 1
        },
        "queuedByDid": {
          "type": "string",
          "description": "DID that queued the song."
        },
        "songId": {
          "type": "string",
          "description": "Queued song id.",
          "minLength": 1,
          "maxLength": 128
        },
        "song": {
          "type": "ref",
          "ref": "#song",
          "description": "Full metadata for the queued song."
        },
        "title": {
          "type": "string",
          "description": "Queued song title.",
          "minLength": 1,
          "maxLength": 512
        },
        "artist": {
          "type": "string",
          "description": "Queued song artist.",
          "minLength": 1,
          "maxLength": 512
        },
        "album": {
          "type": "string",
          "description": "Optional queued song album."
        },
        "durationSeconds": {
          "type": "integer",
          "description": "Optional queued song duration in seconds."
        },
        "addedByDid": {
          "type": "string",
          "description": "DID that originally uploaded the queued song."
        }
      }
    },
    "radioState": {
      "type": "object",
      "description": "Radio playback status persisted by the backend.",
      "required": ["currentSongId", "status", "startedAt", "pausedAt", "positionSeconds", "updatedByDid"],
      "nullable": ["currentSongId", "startedAt", "pausedAt", "updatedByDid", "loopPlaylistId"],
      "properties": {
        "currentSongId": {
          "type": "string",
          "description": "Currently active song id, when one is selected."
        },
        "status": {
          "type": "string",
          "description": "Current playback status.",
          "knownValues": ["playing", "paused", "stopped"]
        },
        "startedAt": {
          "type": "integer",
          "description": "Unix timestamp when playback was last started."
        },
        "pausedAt": {
          "type": "integer",
          "description": "Unix timestamp when playback was last paused."
        },
        "positionSeconds": {
          "type": "integer",
          "description": "Stored playback offset in seconds.",
          "minimum": 0
        },
        "updatedByDid": {
          "type": "string",
          "description": "DID or backend actor that last updated radio state."
        },
        "shuffle": {
          "type": "boolean",
          "description": "Whether the station auto-fills the queue with weighted random picks."
        },
        "loopMode": {
          "type": "string",
          "description": "How finished queue tracks are recycled.",
          "knownValues": ["off", "one", "queue"]
        },
        "loopPlaylistId": {
          "type": "string",
          "description": "Playlist reloaded automatically whenever the queue drains."
        }
      }
    },
    "radioSnapshot": {
      "type": "object",
      "description": "Combined radio view returned to clients.",
      "required": ["state", "currentSong", "queue"],
      "nullable": ["currentSong"],
      "properties": {
        "state": {
          "type": "ref",
          "ref": "#radioState"
        },
        "currentSong": {
          "type": "ref",
          "ref": "#song"
        },
        "nowPlaying": {
          "type": "ref",
          "ref": "#song",
          "description": "Compatibility alias for the current song."
        },
        "queue": {
          "type": "array",
          "description": "Upcoming queued songs.",
          "items": {
            "type": "ref",
            "ref": "#queueItem"
          }
        }
      }
    },
    "songUrlSource": {
      "type": "object",
      "description": "Remote audio source to import through the existing backend URL importer.",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "HTTP(S) audio, playlist, or yt-dlp-supported URL to import.",
          "minLength": 8,
          "maxLength": 4096
        },
        "title": {
          "type": "string",
          "description": "Optional title override for plain audio URLs."
        },
        "artist": {
          "type": "string",
          "description": "Optional artist override for plain audio URLs."
        },
        "album": {
          "type": "string",
          "description": "Optional album override."
        },
        "addToQueue": {
          "type": "boolean",
          "description": "Whether imported songs should be queued immediately.",
          "default": false
        }
      }
    },
    "adminPermission": {
      "type": "object",
      "description": "Permission surfaced in the admin panel.",
      "required": ["key", "description"],
      "properties": {
        "key": {
          "type": "string",
          "description": "Stable permission key used by backend feature gates."
        },
        "description": {
          "type": "string",
          "description": "Human-readable permission description."
        }
      }
    },
    "adminPermissions": {
      "type": "object",
      "description": "Configured admin DID whitelist and available permissions.",
      "required": ["whitelistedDids", "permissions"],
      "properties": {
        "whitelistedDids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#adminPermission"
          }
        }
      }
    },
    "radioAlbum": {
      "type": "object",
      "description": "Admin-defined album loop metadata.",
      "required": ["id", "title", "position", "isEnabled", "tracks"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "position": {
          "type": "integer",
          "minimum": 1
        },
        "isEnabled": {
          "type": "boolean"
        },
        "tracks": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#song"
          }
        }
      }
    },
    "playlist": {
      "type": "object",
      "description": "Saved playlist/set of songs.",
      "required": ["id", "name", "createdAt", "tracks"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "createdAt": {
          "type": "integer",
          "minimum": 0
        },
        "tracks": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#song"
          }
        },
        "shuffleOnLoad": {
          "type": "boolean",
          "description": "Randomize track order whenever this playlist is loaded into the queue."
        }
      }
    },
    "chatMessage": {
      "type": "object",
      "description": "A single persisted chat message.",
      "required": ["id", "senderDid", "body", "createdAt", "kind"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "senderDid": {
          "type": "string",
          "description": "DID that sent the message."
        },
        "body": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "createdAt": {
          "type": "integer",
          "minimum": 0
        },
        "kind": {
          "type": "string",
          "knownValues": ["user", "now_playing"]
        }
      }
    },
    "chatBan": {
      "type": "object",
      "description": "Banned DID record returned to admin tooling.",
      "required": ["did", "bannedByDid", "reason", "createdAt"],
      "nullable": ["reason"],
      "properties": {
        "did": {
          "type": "string"
        },
        "bannedByDid": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "subsonicSongResult": {
      "type": "object",
      "description": "Search result returned from a Subsonic server.",
      "required": ["id", "title", "artist", "album", "durationSeconds", "coverArtId"],
      "nullable": ["album", "durationSeconds", "coverArtId"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "artist": {
          "type": "string"
        },
        "album": {
          "type": "string"
        },
        "durationSeconds": {
          "type": "integer"
        },
        "coverArtId": {
          "type": "string"
        }
      }
    }
  }
}
