{
  "lexicon": 1,
  "id": "pet.nkp.radio.subsonic.import",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Import from a Subsonic song id or public share URL.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["source", "addToQueue"],
          "properties": {
            "source": {
              "type": "string",
              "knownValues": ["song", "share"]
            },
            "serverUrl": { "type": "string", "format": "uri" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "songId": { "type": "string" },
            "coverArtId": { "type": "string" },
            "shareUrl": { "type": "string", "format": "uri" },
            "addToQueue": { "type": "boolean", "default": false }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["song"],
          "properties": {
            "song": {
              "type": "ref",
              "ref": "pet.nkp.radio#song"
            }
          }
        }
      },
      "errors": [
        { "name": "AuthenticationRequired" },
        { "name": "AdminRequired" },
        { "name": "InvalidRequest" },
        { "name": "SubsonicFailed" }
      ]
    }
  }
}
