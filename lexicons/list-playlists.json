{
  "lexicon": 1,
  "id": "pet.nkp.radio.playlists.list",
  "defs": {
    "main": {
      "type": "query",
      "description": "List saved playlists.",
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["playlists"],
          "properties": {
            "playlists": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "pet.nkp.radio#playlist"
              }
            }
          }
        }
      },
      "errors": [
        { "name": "AuthenticationRequired" },
        { "name": "AdminRequired" },
        { "name": "InvalidRequest" }
      ]
    }
  }
}
