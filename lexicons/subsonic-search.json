{
  "lexicon": 1,
  "id": "pet.nkp.radio.subsonic.search",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Search a Subsonic-compatible server for songs.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["serverUrl", "username", "password", "query"],
          "properties": {
            "serverUrl": { "type": "string", "format": "uri" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "query": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["results"],
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "pet.nkp.radio#subsonicSongResult"
              }
            }
          }
        }
      },
      "errors": [
        { "name": "AuthenticationRequired" },
        { "name": "AdminRequired" },
        { "name": "InvalidRequest" },
        { "name": "SubsonicFailed" }
      ]
    }
  }
}
