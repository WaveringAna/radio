{
  "lexicon": 1,
  "id": "pet.nkp.radio.playlists.modify",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Create, edit, delete, or load a saved playlist.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["action"],
          "properties": {
            "action": {
              "type": "string",
              "description": "Playlist operation to perform. Required companion fields are enforced by the server.",
              "knownValues": [
                "create",
                "delete",
                "load",
                "rename",
                "addTracks",
                "removeTrack",
                "reorder",
                "duplicate",
                "setShuffleOnLoad",
                "sequenceTracks"
              ]
            },
            "playlistId": {
              "type": "string"
            },
            "name": {
              "type": "string",
              "description": "New playlist name for create, rename, and duplicate."
            },
            "songIds": {
              "type": "array",
              "description": "Track song ids: the full contents for create, the appended tracks for addTracks, the complete new order for reorder.",
              "items": { "type": "string" }
            },
            "position": {
              "type": "integer",
              "description": "One-based track position to drop when action is removeTrack."
            },
            "shuffleOnLoad": {
              "type": "boolean",
              "description": "Whether loading this playlist randomizes its order."
            },
            "shuffle": {
              "type": "boolean",
              "description": "Overrides the playlist's stored shuffleOnLoad for this load only."
            },
            "replace": {
              "type": "boolean",
              "default": false
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "playlist": {
              "type": "ref",
              "ref": "pet.nkp.radio#playlist"
            },
            "snapshot": {
              "type": "ref",
              "ref": "pet.nkp.radio#radioSnapshot"
            }
          }
        }
      },
      "errors": [
        { "name": "AuthenticationRequired" },
        { "name": "AdminRequired" },
        { "name": "InvalidRequest" },
        { "name": "PlaylistNotFound" }
      ]
    }
  }
}
